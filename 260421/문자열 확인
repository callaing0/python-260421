#Q. word 안에 동렬  이름이 없다라는 것을 확인할 수 있는 코드를 만드세요
word = "나는 진섭이가 짝꿍일때 별로였다"

if '이동렬' not in word :
    print("이동렬이라는 이름은 없습니다.")


#startswith() 함수 시작 문자열 비교

word = "차도헌님께서 입장하셨습니다."

if word.startswith('이창호'):
    print("신원 확인")
else:
    print("이창호님이 아닙니다.")
